# DailyHub AI production environment example
# Fill these in Vercel Project Settings > Environment Variables.

# App
NEXT_PUBLIC_APP_NAME="DailyHub AI"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
APP_TIMEZONE="Asia/Bangkok"

# Supabase - required for production persistence and auth
USE_SUPABASE="true"
ALLOW_MOCK_USER="false"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SECRET_KEY="your-service-role-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Admin protection - set at least ADMIN_EMAILS or ADMIN_USER_IDS.
# ADMIN_SECRET is for server-to-server admin API checks.
ADMIN_SECRET="generate-a-strong-random-secret-here"
ADMIN_EMAILS="owner@example.com"
ADMIN_USER_IDS=""
ENABLE_ADMIN_DASHBOARD="true"

# AI provider - backend only
AI_PROVIDER="groq"
ENABLE_AI="true"
AI_FALLBACK_TO_MOCK="false"

ENABLE_GROQ="true"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_TRANSLATION_MODEL="llama-3.3-70b-versatile"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

ENABLE_OPENAI="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_FALLBACK_TO_MOCK="false"

# Translation
AI_TRANSLATION_ENABLED="true"
TRANSLATION_TARGET_LANGUAGE="th"

# Telegram - backend only
ENABLE_TELEGRAM="true"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_BASE_URL="https://api.telegram.org"
TELEGRAM_FALLBACK_TO_MOCK="false"

# Scheduler - GitHub Actions cron sends Authorization: Bearer CRON_SECRET
ENABLE_SCHEDULER="true"
CRON_SECRET="generate-a-strong-random-secret-here"
SCHEDULER_SECRET="generate-a-strong-random-secret-here"

# Usage limits
ENABLE_USAGE_LIMITS="true"
DAILY_RUN_NOW_LIMIT="30"
DAILY_RUN_ALL_LIMIT="50"
DAILY_OPENAI_CALL_LIMIT="100"
DAILY_TELEGRAM_LIMIT="100"
MAX_TASKS_PER_USER="50"

# Data sources
ENABLE_REAL_DATA_SOURCES="true"
ENABLE_NEWS_SOURCE="true"
NEWS_API_KEY=""
NEWS_QUERY="artificial intelligence OR technology"

ENABLE_WEATHER_SOURCE="true"
WEATHER_LATITUDE="13.7563"
WEATHER_LONGITUDE="100.5018"
WEATHER_LOCATION_NAME="Bangkok"

ENABLE_GMAIL_SOURCE="false"
ENABLE_PRODUCT_SOURCE="false"
ENABLE_FOOTBALL_SOURCE="false"
ENABLE_CONCERT_SOURCE="false"
